# Local development (matches docker-compose.yml)
DATABASE_URL=postgresql://saudiipo:saudiipo@localhost:5432/saudiipo

# Production: Neon pooled connection string. Set in Vercel and in the GitHub
# Actions secret DATABASE_URL. Never commit the real value. NEEDS HUMAN to create.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Optional: a separate direct (non-pooled) URL for migrations and the cron job,
# if you follow Neon's pooled-versus-direct guidance.
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Public site URL used for Open Graph and canonical tags (Phase 7).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sahmk API key for the daily live-price sweep (scripts/live_prices.py). Used only by
# the Python ingester, never by the Next app, so it stays server-side and out of the
# browser bundle. Free tier is 100 requests/day and 10/min. Set in .env locally and in
# the GitHub Actions secret SAHMK_API_KEY. Never commit the real value. NEEDS HUMAN.
# SAHMK_API_KEY=shmk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
