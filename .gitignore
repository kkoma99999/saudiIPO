# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# python
scripts/.venv/
__pycache__/
*.pyc
.pytest_cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# local font archive and design scratch (the app uses src/app/fonts/thmanyah)
Thmanyah-Font-Family/
design-mockups/

# browser automation scratch
.playwright-mcp/

# prospectus (نشرة الإصدار) archive: a local-only extraction workspace of large PDFs and
# text dumps. The whole folder is ignored and never pushed; each data row keeps its own
# source_url, so no provenance is lost. Kept on disk locally.
data/prospectuses/
