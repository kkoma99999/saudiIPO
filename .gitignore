# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# python
scripts/.venv/
__pycache__/
*.pyc
.pytest_cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# local font archive and design scratch (the app uses src/app/fonts/thmanyah)
Thmanyah-Font-Family/
design-mockups/

# browser automation scratch
.playwright-mcp/

# prospectus (نشرة الإصدار) PDF archive: large binaries kept locally for extraction.
# The manifest data/prospectuses/sources.csv is tracked; the PDFs and text dumps are not.
data/prospectuses/*.pdf
data/prospectuses/*.txt
data/prospectuses/extract_args.json
